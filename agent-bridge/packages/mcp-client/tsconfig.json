{
  "compilerOptions": {
    "target": "ES2022",
    "types": ["node"],
    "typeRoots": ["../../plugins/openclaw/node_modules/@types"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts"]
}
