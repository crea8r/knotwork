{
  "name": "@knotwork/knotwork-bridge",
  "version": "1.0.0",
  "description": "Knotwork bridge plugin for OpenClaw — connects OpenClaw agents to Knotwork workflows",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "package:tarball": "python3 scripts/package_tarball.py",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.3"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
