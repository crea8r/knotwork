{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@app-shell": ["index.ts"],
      "@app-shell/*": ["*"],
      "@core-api/*": ["../api/*"],
      "@distributions/*": ["../../distributions/*"],
      "@ui/*": ["../../libs/ui/*"],
      "@sdk": ["../../libs/sdk/index.ts"],
      "@sdk/*": ["../../libs/sdk/*"],
      "@data-models": ["../../libs/data-models/index.ts"],
      "@auth": ["../../libs/auth/index.ts"],
      "@modules/*": ["../../modules/*"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "react-dom/*": ["./node_modules/@types/react-dom/*", "./node_modules/react-dom/*"],
      "axios": ["./node_modules/axios/index.d.ts"],
      "zustand": ["./node_modules/zustand"],
      "zustand/*": ["./node_modules/zustand/*"],
      "@tiptap/react": ["./node_modules/@tiptap/react"],
      "@tiptap/starter-kit": ["./node_modules/@tiptap/starter-kit"],
      "@tiptap/extension-underline": ["./node_modules/@tiptap/extension-underline"],
      "@tiptap/extension-highlight": ["./node_modules/@tiptap/extension-highlight"],
      "@tiptap/extension-text-style": ["./node_modules/@tiptap/extension-text-style"],
      "@tiptap/extension-color": ["./node_modules/@tiptap/extension-color"],
      "@tiptap/extension-link": ["./node_modules/@tiptap/extension-link"],
      "marked": ["./node_modules/marked/lib/marked.d.ts"],
      "turndown": ["./node_modules/@types/turndown/index.d.ts"],
      "react-markdown": ["./node_modules/react-markdown"],
      "remark-gfm": ["./node_modules/remark-gfm"],
      "rehype-raw": ["./node_modules/rehype-raw"],
      "react-router-dom": ["./node_modules/react-router-dom"],
      "lucide-react": ["./node_modules/lucide-react"],
      "@tanstack/react-query": ["./node_modules/@tanstack/react-query"],
      "@dagrejs/dagre": ["./node_modules/@types/dagre/index.d.ts"]
    }
  },
  "include": [
    "vite-env.d.ts",
    "./**/*.ts",
    "./**/*.tsx",
    "../../libs/**/*.ts",
    "../../libs/**/*.tsx",
    "../../distributions/**/*.ts",
    "../../distributions/**/*.tsx",
    "../../modules/**/*.ts",
    "../../modules/**/*.tsx",
    "../api/**/*.ts",
    "../api/**/*.tsx"
  ],
  "exclude": [
    "vite.config.ts"
  ]
}
