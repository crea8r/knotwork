# Knotwork — Docker environment template
# Copy this to .env and fill in your values.
# DB and Redis URLs are overridden by docker-compose.yml — no need to change them.

# Docker resource ownership
COMPOSE_PROJECT_NAME=knotwork-local
KNOTWORK_NETWORK_NAME=knotwork-local-network

# Database (docker-compose sets these automatically)
DATABASE_URL=postgresql+asyncpg://knotwork:knotwork@postgres:5432/knotwork
DATABASE_URL_SYNC=postgresql://knotwork:knotwork@postgres:5432/knotwork

# Redis (docker-compose sets this automatically)
REDIS_URL=redis://redis:6379

# Storage
STORAGE_ADAPTER=local_fs
LOCAL_FS_ROOT=/app/data/knowledge

# LLM (at least one required)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=openai/gpt-4o

# Auth (required — generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-generate-a-real-secret

# Dev bypass: if set, all API calls are authenticated as this user without JWT
# Find your user UUID after first login. Leave empty in prod.
AUTH_DEV_BYPASS_USER_ID=

# App base URL (used in magic link emails)
FRONTEND_URL=http://localhost:3000
# Backend base URL (used in OpenClaw install links and attachment download URLs)
BACKEND_URL=http://localhost:8000
# External URL for the OpenClaw plugin artifact (.tar.gz). Knotwork advertises
# this URL in the install bundle but does not build or serve the plugin.
OPENCLAW_PLUGIN_PACKAGE_URL=

# Email for magic link / invite emails — via Resend (https://resend.com)
RESEND_API=re_...
EMAIL_FROM=noreply@yourdomain.com

# Notifications (optional)
# TELEGRAM_BOT_TOKEN=...
