# Database
DATABASE_URL=postgresql+asyncpg://knotwork:knotwork@localhost:5432/knotwork

# Redis
REDIS_URL=redis://localhost:6379

# Storage (local_fs for dev, s3 for prod)
STORAGE_ADAPTER=local_fs
LOCAL_FS_ROOT=./data/knowledge
# S3_BUCKET=
# S3_REGION=ap-southeast-1

# LLM (at least one required)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=openai/gpt-4o

# Auth
JWT_SECRET=change-me-in-production

# OpenClaw plugin
OPENCLAW_PLUGIN_PACKAGE_URL=https://lab.crea8r.xyz/kw-plugin/latest

# Notifications (optional for dev)
# TELEGRAM_BOT_TOKEN=
# RESEND_API=re_...              # from resend.com — used for magic link + invite emails
# EMAIL_FROM=noreply@yourdomain.com
